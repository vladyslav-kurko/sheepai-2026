{
  "info": {
    "title": "The GoOver API",
    "version": "1.0.0"
  },
  "openapi": "3.1.1",
  "paths": {
    "/chat/test": {
      "post": {
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "500": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/auth/signup": {
      "post": {
        "responses": {
          "201": {
            "description": "User created, tokens set in cookies"
          },
          "409": {
            "description": "Email already registered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupRequest"
              }
            }
          }
        },
        "summary": "Register a new user",
        "tags": [
          "Authentication"
        ]
      }
    },
    "/auth/signin": {
      "post": {
        "responses": {
          "200": {
            "description": "Authenticated, tokens set in cookies"
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SigninRequest"
              }
            }
          }
        },
        "summary": "Sign in with email and password",
        "tags": [
          "Authentication"
        ]
      }
    },
    "/auth/refresh": {
      "post": {
        "responses": {
          "200": {
            "description": "Access token refreshed and set in cookie"
          },
          "401": {
            "description": "Invalid or expired refresh token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "summary": "Refresh access token using refresh token cookie",
        "tags": [
          "Authentication"
        ]
      }
    },
    "/conversations": {
      "get": {
        "description": "Retrieves a paginated list of conversations for the authenticated user. Requires authentication.",
        "responses": {
          "200": {
            "description": "Paginated list of conversations for the authenticated user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationListDTO"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "tags": [
          "Conversations"
        ]
      },
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateConversationRequestDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Conversation created with initial assistant response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatedConversationDTO"
                }
              }
            }
          }
        },
        "tags": [
          "Conversations"
        ]
      }
    },
    "/conversations/{id}/messages": {
      "get": {
        "responses": {
          "200": {
            "description": "Paginated messages for a conversation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageListDTO"
                }
              }
            }
          },
          "404": {
            "description": "Conversation not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Conversation ID"
          }
        ],
        "description": "Retrieves a conversation by ID along with its message history. This endpoint is deprecated in favor of GET /conversations/{id}/messages for paginated messages.",
        "tags": [
          "Conversations"
        ]
      }
    },
    "/conversations/{id}": {
      "get": {
        "description": "Use GET /conversations/{id}/messages for paginated messages instead",
        "deprecated": true,
        "responses": {
          "200": {
            "description": "Conversation with message history",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationWithMessagesDTO"
                }
              }
            }
          },
          "404": {
            "description": "Conversation not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Conversation ID"
          }
        ],
        "tags": [
          "Conversations"
        ]
      }
    },
    "/conversations/messages/{id}": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequestDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Assistant response to the new message",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponseDTO"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Conversation ID"
          }
        ],
        "tags": [
          "Conversations"
        ]
      }
    },
    "/maps/geocode": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GeocodeRequestDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Geocoded coordinates for the given address",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeocodeResponseDTO"
                }
              }
            }
          },
          "404": {
            "description": "Address not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "tags": [
          "Maps"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "ApiError": {
        "properties": {
          "statusCode": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "type": "object",
        "required": [
          "statusCode",
          "message",
          "details"
        ]
      },
      "SignupRequest": {
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "type": "object",
        "required": [
          "email",
          "password",
          "name"
        ]
      },
      "SigninRequest": {
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        },
        "type": "object",
        "required": [
          "email",
          "password"
        ]
      },
      "ConversationListDTO": {
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ConversationEntity"
            }
          },
          "total": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "limit": {
            "type": "number"
          }
        },
        "type": "object",
        "required": [
          "items",
          "total",
          "page",
          "limit"
        ]
      },
      "ConversationEntity": {
        "properties": {
          "id": {
            "type": "string"
          },
          "userId": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "type": "object",
        "required": [
          "id",
          "userId",
          "title",
          "createdAt",
          "updatedAt"
        ]
      },
      "MessageListDTO": {
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AssistantMessageEntity"
            }
          },
          "total": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "limit": {
            "type": "number"
          }
        },
        "type": "object",
        "required": [
          "items",
          "total",
          "page",
          "limit"
        ]
      },
      "AssistantMessageEntity": {
        "properties": {
          "id": {
            "type": "string"
          },
          "conversationId": {
            "type": "string"
          },
          "sender": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ]
          },
          "content": {
            "$ref": "#/components/schemas/ModulesPayloadSchema"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "type": "object",
        "required": [
          "id",
          "conversationId",
          "sender",
          "content",
          "createdAt",
          "updatedAt"
        ]
      },
      "ModulesPayloadSchema": {
        "properties": {
          "modulesToRender": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "data": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "type": "object",
        "required": [
          "modulesToRender",
          "data"
        ]
      },
      "ConversationWithMessagesDTO": {
        "properties": {
          "conversation": {
            "$ref": "#/components/schemas/ConversationEntity"
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MessageEntity"
            }
          }
        },
        "type": "object",
        "required": [
          "conversation",
          "messages"
        ]
      },
      "MessageEntity": {
        "properties": {
          "id": {
            "type": "string"
          },
          "conversationId": {
            "type": "string"
          },
          "sender": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ]
          },
          "content": {
            "type": "object",
            "additionalProperties": true
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "type": "object",
        "required": [
          "id",
          "conversationId",
          "sender",
          "content",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateConversationRequestDTO": {
        "properties": {
          "message": {
            "type": "string",
            "required": true
          },
          "chipAnswer": {
            "$ref": "#/components/schemas/ChipAnswerDTO"
          }
        },
        "type": "object",
        "required": [
          "message",
          "chipAnswer"
        ]
      },
      "ChipAnswerDTO": {
        "properties": {
          "label": {
            "type": "string"
          },
          "slotKey": {
            "type": "string"
          },
          "slotValue": {
            "type": "string"
          }
        },
        "type": "object",
        "required": [
          "label",
          "slotKey",
          "slotValue"
        ]
      },
      "CreatedConversationDTO": {
        "properties": {
          "conversation": {
            "$ref": "#/components/schemas/ConversationEntity"
          },
          "initialAnswer": {
            "$ref": "#/components/schemas/AssistantMessageEntity"
          }
        },
        "type": "object",
        "required": [
          "conversation",
          "initialAnswer"
        ]
      },
      "SendMessageRequestDTO": {
        "properties": {
          "message": {
            "type": "string",
            "required": true
          },
          "chipAnswer": {
            "$ref": "#/components/schemas/ChipAnswerDTO"
          }
        },
        "type": "object",
        "required": [
          "message",
          "chipAnswer"
        ]
      },
      "MessageResponseDTO": {
        "properties": {
          "message": {
            "$ref": "#/components/schemas/AssistantMessageEntity"
          }
        },
        "type": "object",
        "required": [
          "message"
        ]
      },
      "GeocodeRequestDTO": {
        "properties": {
          "address": {
            "type": "string",
            "required": true
          }
        },
        "type": "object",
        "required": [
          "address"
        ]
      },
      "GeocodeResponseDTO": {
        "properties": {
          "lat": {
            "type": "number"
          },
          "lng": {
            "type": "number"
          },
          "displayName": {
            "type": "string"
          }
        },
        "type": "object",
        "required": [
          "lat",
          "lng",
          "displayName"
        ]
      }
    }
  }
}